# ==== Shared configuration for the graph-DB performance comparison ====
# Source this file before running provisioning scripts:  source config.env

export RG="rg-graphperf-cus"
export LOC="centralus"

# ---- Neo4j VM ----
export VM_NAME="neo4j-vm"
export VM_SIZE="Standard_D4s_v5"          # 4 vCPU / 16 GB
export VM_IMAGE="Ubuntu2204"
export VM_ADMIN="azureuser"
export VM_DATA_DISK_GB="128"              # Premium SSD data disk for /data
export SSH_KEY="$HOME/projects/NEO4J-Postgre-Cosmos-Perf20260611/.secrets/neo4j_vm_key"

# ---- PostgreSQL Flexible Server ----
export PG_NAME="graphperf-pg-cus"         # must be globally unique
export PG_SKU="Standard_D4ds_v5"          # 4 vCPU / 16 GB, General Purpose
export PG_TIER="GeneralPurpose"
export PG_STORAGE_GB="128"
export PG_VERSION="16"
export PG_ADMIN="pgadmin"
# PG_PASSWORD is generated at provisioning time and stored in .secrets/pg_password

# ---- Cosmos DB (Gremlin API) ----
export COSMOS_NAME="graphperf-gremlin-cus"    # must be globally unique
export COSMOS_DB="graphdb"
export COSMOS_GRAPH="social"
export COSMOS_THROUGHPUT="10000"          # RU/s provisioned (manual)
export COSMOS_PARTITION_KEY="/pk"

# ---- Benchmark dataset scale ----
export NUM_NODES="100000"                 # Person nodes
export NUM_EDGES="1000000"                # KNOWS edges
export SEED="42"
